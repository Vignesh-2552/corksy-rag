# LLM — change provider + model to switch without code changes
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_API_KEY=sk-ant-...

# Embeddings — local sentence-transformers model (no API key required)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VECTOR_SIZE=384

# Qdrant vector database
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=your_collection_name

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64

# Upload
SUPPORTED_EXTENSIONS=.pdf,.txt,.json,.csv,.md
MAX_FILE_SIZE_MB=50

# App settings
APP_ENV=development
LOG_LEVEL=INFO
